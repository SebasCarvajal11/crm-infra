{
  "name": "crm-infra",
  "version": "1.0.0",
  "description": "Platform orchestration, gateway generation, and local infrastructure for the CIMA CRM multi-repo stack.",
  "main": "gateway/build-krakend.mjs",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "gateway:build": "node gateway/build-krakend.mjs",
    "compose:generate": "node scripts/generate-compose.mjs",
    "registry:validate": "node scripts/validate-registry.mjs",
    "portal:build": "node scripts/build-portal.mjs",
    "smoke:multirepo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-multirepo.ps1",
    "verify:frontend-ui": "pnpm dlx @playwright/test test -c scripts/playwright.cutover.config.js",
    "verify:multirepo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-multirepo.ps1",
    "test:contracts": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-contract-tests.ps1",
    "smoke:test": "pnpm dlx @playwright/test test -c scripts/playwright.smoke.config.js",
    "setup:env": "pwsh -File setup/env.ps1",
    "setup:db": "pwsh -File setup/db.ps1",
    "setup:gateway": "pwsh -File setup/gateway.ps1",
    "setup:all": "pnpm setup:env && pnpm setup:gateway && pnpm setup:db",
    "dev:all": "concurrently --names auth,collab,media,frontend --prefix-colors blue,green,yellow,magenta --kill-others-on-fail \"pnpm --dir ../crm-auth dev\" \"pnpm --dir ../crm-collab dev\" \"pnpm --dir ../crm-media dev\" \"pnpm --dir ../crm-frontend dev\"",
    "test:hurl": "tsx tests/hurl-runner.ts --all",
    "test:hurl:auth": "tsx tests/hurl-runner.ts --service=auth",
    "test:hurl:collab": "tsx tests/hurl-runner.ts --service=collab",
    "test:hurl:media": "tsx tests/hurl-runner.ts --service=media",
    "test:hurl:cross": "tsx tests/hurl-runner.ts --service=cross-service",
    "test:seed": "tsx tests/test-seed.ts --verify",
    "preinstall": "pnpm dlx only-allow pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebasCarvajal11/crm-infra.git"
  },
  "keywords": [
    "krakend",
    "docker-compose",
    "platform",
    "microservices"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SebasCarvajal11/crm-infra/issues"
  },
  "homepage": "https://github.com/SebasCarvajal11/crm-infra#readme",
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "concurrently": "^9.1.0",
    "tsx": "^4.22.4"
  }
}
