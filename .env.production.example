COMPOSE_PROJECT_NAME=crm_infra_prod

POSTGRES_USER=root
POSTGRES_PASSWORD=change-me
POSTGRES_DB=crm_database
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
CLAMAV_HOST_PORT=3310

AUTH_DB_PASSWORD=change-me
COLLAB_DB_PASSWORD=change-me
MEDIA_DB_PASSWORD=change-me
MARKETING_DB_PASSWORD=change-me

GATEWAY_HOST_PORT=8080
FRONTEND_HOST_PORT=80
GATEWAY_SLOT_HOST_PORT=18081
FRONTEND_SLOT_HOST_PORT=8081

KRAKEND_AUTH_HOST=http://auth:3000
KRAKEND_COLLAB_HOST=http://collab:3001
KRAKEND_MEDIA_HOST=http://media:3002
KRAKEND_MARKETING_HOST=http://marketing:3003
KRAKEND_ENDPOINTS_SOURCE=file

OCI_CONFIG_HOST_DIR=/opt/cima/secrets/oci
OCI_CONFIG_CONTAINER_DIR=/opt/cima/secrets/oci
