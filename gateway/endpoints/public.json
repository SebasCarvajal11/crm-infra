{
  "_comment": "Endpoints publicos — sin JWT. El build script agrega gateway-trust y headers estandar.",
  "endpoints": [
    {
      "endpoint": "/health",
      "method": "GET",
      "backend_url": "/health"
    },
    {
      "endpoint": "/.well-known/jwks.json",
      "method": "GET",
      "backend_url": "/.well-known/jwks.json"
    },
    {
      "endpoint": "/openapi.yaml",
      "method": "GET",
      "backend_url": "/openapi.yaml",
      "static_file": true
    },
    {
      "endpoint": "/docs",
      "method": "GET",
      "backend_url": "/docs"
    },
    {
      "endpoint": "/auth/login",
      "method": "POST",
      "backend_url": "/auth/login",
      "rate_limit": {
        "client_max_rate": 5,
        "client_capacity": 5,
        "every": "15m",
        "strategy": "ip"
      }
    },
    {
      "endpoint": "/auth/refresh",
      "method": "POST",
      "backend_url": "/auth/refresh",
      "extra_headers": ["Cookie"]
    },
    {
      "endpoint": "/auth/forgot-password",
      "method": "POST",
      "backend_url": "/auth/forgot-password",
      "rate_limit": {
        "client_max_rate": 3,
        "client_capacity": 3,
        "every": "1h",
        "strategy": "ip"
      }
    },
    {
      "endpoint": "/auth/reset-password",
      "method": "POST",
      "backend_url": "/auth/reset-password",
      "rate_limit": {
        "client_max_rate": 5,
        "client_capacity": 5,
        "every": "1h",
        "strategy": "ip"
      }
    },
    {
      "endpoint": "/auth/accept-invite/{token}",
      "method": "GET",
      "backend_url": "/auth/accept-invite/{token}"
    },
    {
      "endpoint": "/auth/accept-invite",
      "method": "POST",
      "backend_url": "/auth/accept-invite",
      "rate_limit": {
        "client_max_rate": 5,
        "client_capacity": 5,
        "every": "1h",
        "strategy": "ip"
      }
    },
    {
      "endpoint": "/auth/verify-email",
      "method": "POST",
      "backend_url": "/auth/verify-email",
      "rate_limit": {
        "client_max_rate": 10,
        "client_capacity": 10,
        "every": "1h",
        "strategy": "ip"
      }
    }
  ]
}
