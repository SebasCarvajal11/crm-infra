{
  "_comment": "Endpoints autenticados de mod-auth — topologia oculta. URLs orientadas a features, no a microservicios.",
  "host": "http://host.docker.internal:3000",
  "endpoints": [
    {
      "endpoint": "/identity/me",
      "method": "GET",
      "backend_url": "/auth/me",
      "allow": [
        "id",
        "email",
        "role",
        "emailVerifiedAt",
        "force_password_change"
      ]
    },
    {
      "endpoint": "/identity/logout",
      "method": "POST",
      "backend_url": "/auth/logout",
      "extra_headers": [
        "Cookie"
      ]
    },
    {
      "endpoint": "/identity/search",
      "method": "GET",
      "backend_url": "/users/search",
      "input_query_strings": [
        "q",
        "role"
      ]
    },
    {
      "endpoint": "/account/password",
      "method": "POST",
      "backend_url": "/auth/change-password"
    },
    {
      "endpoint": "/account/sessions",
      "method": "GET",
      "backend_url": "/auth/sessions"
    },
    {
      "endpoint": "/account/sessions/{familyId}",
      "method": "DELETE",
      "backend_url": "/auth/sessions/{familyId}"
    },
    {
      "endpoint": "/account/verify-email/request",
      "method": "POST",
      "backend_url": "/auth/request-email-verification"
    },
    {
      "endpoint": "/admin/workers",
      "method": "POST",
      "backend_url": "/auth/register-worker"
    },
    {
      "endpoint": "/admin/admins/invite",
      "method": "POST",
      "backend_url": "/auth/invite-admin"
    },
    {
      "endpoint": "/admin/clients/invite",
      "method": "POST",
      "backend_url": "/auth/invite-client"
    },
    {
      "endpoint": "/admin/users",
      "method": "GET",
      "backend_url": "/users",
      "input_query_strings": [
        "page",
        "limit",
        "role",
        "include_deleted",
        "q"
      ],
      "allow": [
        "id",
        "email",
        "role",
        "is_active",
        "deleted_at",
        "force_password_change"
      ]
    },
    {
      "endpoint": "/admin/users/{subject}/status",
      "method": "PATCH",
      "backend_url": "/users/{subject}/status"
    },
    {
      "endpoint": "/admin/users/{subject}/flags",
      "method": "PATCH",
      "backend_url": "/users/{subject}/flags"
    },
    {
      "endpoint": "/admin/users/{subject}/restore",
      "method": "POST",
      "backend_url": "/users/{subject}/restore"
    },
    {
      "endpoint": "/admin/users/{subject}",
      "method": "DELETE",
      "backend_url": "/users/{subject}"
    }
  ]
}
