{
  "_comment": "Endpoints de mod-collab — topologia oculta. /collab/* eliminado. URLs orientadas a recursos.",
  "host": "http://mod-collab:3001",
  "endpoints": [
    {
      "endpoint": "/projects",
      "method": "GET",
      "backend_url": "/collab/projects",
      "allow": [
        "id",
        "name",
        "clientName",
        "type",
        "status",
        "progressPercent",
        "unreadNotifications"
      ],
      "cache_ttl": "60s"
    },
    {
      "endpoint": "/projects",
      "method": "POST",
      "backend_url": "/collab/projects"
    },
    {
      "endpoint": "/projects/{projectId}",
      "method": "PATCH",
      "backend_url": "/collab/projects/{projectId}"
    },
    {
      "endpoint": "/projects/{projectId}/workspace",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/workspace"
    },
    {
      "endpoint": "/projects/{projectId}/members",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/members"
    },
    {
      "endpoint": "/projects/{projectId}/members",
      "method": "PUT",
      "backend_url": "/collab/projects/{projectId}/members"
    },
    {
