{
  "_comment": "Endpoints de mod-collab — topologia oculta. /collab/* eliminado. URLs orientadas a recursos.",
  "host": "http://host.docker.internal:3001",
  "endpoints": [
    {
      "endpoint": "/projects",
      "method": "GET",
      "backend_url": "/collab/projects",
      "allow": [
        "id",
        "name",
        "clientName",
        "type",
        "status",
        "progressPercent",
        "unreadNotifications"
      ]
    },
    {
      "endpoint": "/projects/search",
      "method": "GET",
      "backend_url": "/collab/projects/search",
      "input_query_strings": [
        "q",
        "limit"
      ]
    },
    {
      "endpoint": "/projects",
      "method": "POST",
      "backend_url": "/collab/projects"
    },
    {
      "endpoint": "/projects/{projectId}",
      "method": "PATCH",
      "backend_url": "/collab/projects/{projectId}"
    },
    {
      "endpoint": "/projects/{projectId}/board",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/board"
    },
    {
      "endpoint": "/projects/{projectId}/workspace",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/workspace"
    },
    {
      "endpoint": "/projects/{projectId}/members",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/members"
    },
    {
      "endpoint": "/projects/{projectId}/members",
      "method": "PUT",
      "backend_url": "/collab/projects/{projectId}/members"
    },
    {
      "endpoint": "/projects/{projectId}/columns",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/columns"
    },
    {
      "endpoint": "/projects/{projectId}/columns",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/columns"
    },
    {
      "endpoint": "/columns/{columnId}",
      "method": "PATCH",
      "backend_url": "/collab/columns/{columnId}"
    },
    {
      "endpoint": "/projects/{projectId}/tasks",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/tasks",
      "allow": [
        "id",
        "columnId",
        "title",
        "description",
        "priority",
        "deadline",
        "checklistProgress",
        "isClientVisible",
        "createdAt",
        "updatedAt"
      ]
    },
    {
      "endpoint": "/projects/{projectId}/tasks",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/tasks"
    },
    {
      "endpoint": "/tasks/{taskId}",
      "method": "PATCH",
      "backend_url": "/collab/tasks/{taskId}"
    },
    {
      "endpoint": "/projects/{projectId}/chat/internal",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/chat/internal"
    },
    {
      "endpoint": "/projects/{projectId}/chat/internal",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/chat/internal"
    },
    {
      "endpoint": "/projects/{projectId}/chat/internal/read",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/chat/internal/read"
    },
    {
      "endpoint": "/projects/{projectId}/chat/external",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/chat/external"
    },
    {
      "endpoint": "/projects/{projectId}/chat/external",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/chat/external"
    },
    {
      "endpoint": "/projects/{projectId}/chat/external/read",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/chat/external/read"
    },
    {
      "endpoint": "/notifications/chat-mentions/unread",
      "method": "GET",
      "backend_url": "/collab/notifications/chat-mentions/unread"
    },
    {
      "endpoint": "/notifications/chat-mentions/unread/count",
      "method": "GET",
      "backend_url": "/collab/notifications/chat-mentions/unread/count"
    },
    {
      "endpoint": "/notifications/chat-mentions/{notificationId}/read",
      "method": "PATCH",
      "backend_url": "/collab/notifications/chat-mentions/{notificationId}/read"
    },
    {
      "endpoint": "/projects/{projectId}/change-requests/minor",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/change-requests/minor"
    },
    {
      "endpoint": "/projects/{projectId}/change-requests/formal",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/change-requests/formal"
    },
    {
      "endpoint": "/projects/{projectId}/change-requests/{changeRequestId}",
      "method": "PATCH",
      "backend_url": "/collab/projects/{projectId}/change-requests/{changeRequestId}"
    },
    {
      "endpoint": "/projects/{projectId}/change-log/formal",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/change-log/formal"
    },
    {
      "endpoint": "/projects/{projectId}/files",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/files"
    },
    {
      "endpoint": "/projects/{projectId}/files",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/files"
    },
    {
      "endpoint": "/projects/{projectId}/timeline",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/timeline"
    },
    {
      "endpoint": "/projects/{projectId}/files/timeline",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/files/timeline"
    },
    {
      "_comment": "Pre-Signed URL flow: Paso 1 para archivos de proyecto",
      "endpoint": "/projects/{projectId}/files/upload-url",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/files/upload-url"
    },
    {
      "endpoint": "/files/{fileId}/approve",
      "method": "PATCH",
      "backend_url": "/collab/files/{fileId}/approve"
    },
    {
      "endpoint": "/files/{fileId}/download",
      "method": "GET",
      "backend_url": "/collab/files/{fileId}/download",
      "input_query_strings": [
        "preview"
      ]
    },
    {
      "endpoint": "/files/{fileId}/access",
      "method": "GET",
      "backend_url": "/collab/files/{fileId}/access",
      "input_query_strings": [
        "preview"
      ]
    },
    {
      "endpoint": "/files/{fileId}",
      "method": "DELETE",
      "backend_url": "/collab/files/{fileId}"
    },
    {
      "endpoint": "/files/{fileId}",
      "method": "PATCH",
      "backend_url": "/collab/files/{fileId}"
    },
    {
      "endpoint": "/projects/{projectId}/tasks/{taskId}/comments",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/tasks/{taskId}/comments"
    },
    {
      "endpoint": "/projects/{projectId}/tasks/{taskId}/comments",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/tasks/{taskId}/comments"
    },
    {
      "endpoint": "/projects/{projectId}/tasks/{taskId}/files",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/tasks/{taskId}/files"
    },
    {
      "_comment": "Pre-Signed URL flow: Paso 1 para archivos de tarea",
      "endpoint": "/projects/{projectId}/tasks/{taskId}/files/upload-url",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/tasks/{taskId}/files/upload-url"
    },
    {
      "endpoint": "/projects/{projectId}/tasks/{taskId}/files/metadata",
      "method": "POST",
      "backend_url": "/collab/projects/{projectId}/tasks/{taskId}/files/metadata"
    },
    {
      "endpoint": "/projects/{projectId}/brief",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/brief"
    },
    {
      "endpoint": "/projects/{projectId}/brief",
      "method": "PATCH",
      "backend_url": "/collab/projects/{projectId}/brief"
    },
    {
      "endpoint": "/bff/workspace/{projectId}",
      "method": "GET",
      "backend_url": "/collab/projects/{projectId}/workspace"
    }
  ]
}
