COMPOSE_PROJECT_NAME=crm_infra_local
GATEWAY_HOST_PORT=18080

# ── Gateway → Servicios ──────────────────────────────────────────────────────
# Para desarrollo híbrido (servicios en host):
KRAKEND_AUTH_HOST=http://127.0.0.1:3000
KRAKEND_COLLAB_HOST=http://127.0.0.1:3001
KRAKEND_MEDIA_HOST=http://127.0.0.1:3002
# Para desarrollo con Docker (todos los servicios en contenedores):
# KRAKEND_AUTH_HOST=http://crm-auth:3000
# KRAKEND_COLLAB_HOST=http://crm-collab:3001
# KRAKEND_MEDIA_HOST=http://crm-media:3002

POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
CLAMAV_HOST_PORT=13310
AUTH_DB_PASSWORD=authpassword
COLLAB_DB_PASSWORD=collabpassword
MEDIA_DB_PASSWORD=mediapassword

# Produccion
# POSTGRES_PASSWORD=change-me

# ── Observabilidad ────────────────────────────────────────────────────────────
# Puertos del stack de observabilidad (dev local)
PROMETHEUS_HOST_PORT=19090
LOKI_HOST_PORT=13100
GRAFANA_HOST_PORT=13000

# Credenciales de Grafana (cambiar en producción)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
